{
  "app_env": "development",
  "tenant": {
    "tenant_id": "default-company",
    "company_id": "default-company"
  },
  "runtime": {
    "data_root": ".rotahub_runtime",
    "db_path": ".rotahub_runtime/server/development/default-company/rotahub_server.db",
    "sync_enabled": false,
    "sql_mirror_api": false,
    "require_server_binding": false,
    "allow_remote_write": false,
    "allow_remote_read": false,
    "allow_dev_data_upload": false,
    "allow_seed_db": false,
    "allow_version_update": false,
    "tenant_mode": "database-per-tenant",
