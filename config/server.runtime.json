{
  "app_env": "production",
  "tenant": {
    "tenant_id": "default-company",
    "company_id": "default-company"
  },
  "runtime": {
    "data_root": ".rotahub_runtime",
    "db_path": ".rotahub_runtime/server/production/default-company/rotahub_server.db",
    "sync_enabled": false,
    "sql_mirror_api": false,
    "require_server_binding": false,
    "allow_remote_write": false,
    "allow_remote_read": false,
    "allow_dev_data_upload": false,
    "allow_seed_db": false,
    "allow_version_update": false,
    "tenant_mode": "database-per-tenant",
    "source_of_truth": "sqlite-local",
    "schema_version": 1,
    "desktop_secret": ""
  },
  "api": {
    "base_url": "https://rotahub-api.onrender.com",
    "timeout": 60.0
  },
  "logging": {
    "level": "INFO"
  },
  "update": {
    "channel": "stable",
    "manifest_url": "https://raw.githubusercontent.com/andersoncantenas-glitch/rotahub-api/main/updates/version.json",
    "setup_url": "",
    "changelog_url": ""
  }
}
