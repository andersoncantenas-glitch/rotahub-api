{
  "app_env": "production",
  "app_title": "ROTAHUB DESKTOP",
  "tenant": {
    "tenant_id": "default-company",
    "company_id": "default-company"
  },
  "runtime": {
    "sync_enabled": true,
    "sql_mirror_api": true,
    "require_server_binding": true,
    "allow_remote_write": true,
    "allow_remote_read": true,
    "allow_dev_data_upload": false,
    "allow_seed_db": false,
    "source_of_truth": "api-central"
  },
  "api": {
    "base_url": "https://rotahub-api.onrender.com",
    "timeout": 60
  },
  "update": {
    "manifest_url": "https://raw.githubusercontent.com/andersoncantenas-glitch/rotahub-api/main/updates/version.json",
    "setup_url": "",
    "changelog_url": ""
  },
  "support": {
    "whatsapp": "",
    "email": ""
  }
}
