# .env.example
# Copy this file to .env and adjust values for your environment

# Environment
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Database
# Local SQLite default. In production prefer a persistent disk path or PostgreSQL.
ROTA_DB=./rotadb.db
DATABASE_URL=sqlite+aiosqlite:///./rotadb.db

# Security
SECRET_KEY=your-super-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://localhost:6379

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# File Upload
MAX_UPLOAD_SIZE=10485760
ROTA_MOBILE_PHOTOS_DIR=./.rotahub_runtime/fotos_rotas
ROTA_ENABLE_LEGACY_MOBILE_API=1
ROTA_SECRET=change-this-mobile-sync-secret

# SaaS Settings
DEFAULT_PLAN_VEHICLES=5
MAX_FREE_VEHICLES=2
