# RotaHub Web - exemplo para servidor
# Copie para .env no servidor e ajuste dominio, segredos e caminhos.

ENVIRONMENT=production
DEBUG=false
HOST=0.0.0.0
PORT=8000

# Dominio/IP publico do servidor. Inclua localhost somente se usar healthcheck local.
ALLOWED_HOSTS=seudominio.com.br,www.seudominio.com.br,127.0.0.1,localhost
CORS_ORIGINS=https://seudominio.com.br,https://www.seudominio.com.br

# Opcao A: SQLite em disco persistente da VPS.
ROTA_DATA_ROOT=/var/rotahub/data
ROTA_DB=/var/rotahub/data/rotadb.db
DATABASE_URL=sqlite+aiosqlite:////var/rotahub/data/rotadb.db
BACKUP_DIR=/var/rotahub/data/backups
ROTA_EXPORT_DIR=/var/rotahub/data/exports

# Opcao B: PostgreSQL. Use esta opcao quando contratar banco gerenciado.
# DATABASE_URL=postgresql://usuario:senha@host:5432/rotadb

# Segredos: gere valores longos e diferentes.
SECRET_KEY=troque-por-um-segredo-longo
JWT_SECRET_KEY=troque-por-outro-segredo-longo
ROTA_SECRET=troque-por-segredo-do-app-motorista

# App motorista / fotos.
ROTA_ENABLE_LEGACY_MOBILE_API=1
ROTA_MOBILE_PHOTOS_DIR=/var/rotahub/data/fotos_rotas
MAX_UPLOAD_SIZE=10485760

# Limites.
RATE_LIMIT_REQUESTS=300
RATE_LIMIT_WINDOW=60

# SaaS.
DEFAULT_PLAN_VEHICLES=5
MAX_FREE_VEHICLES=2
